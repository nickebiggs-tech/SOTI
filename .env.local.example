# SOTI Environment Configuration
# Copy this file to .env.local and fill in your values

# ---- Authentication ----
# Auth mode: 'local' (default) or 'ldap'
VITE_AUTH_MODE=local

# LDAP Configuration (only needed if VITE_AUTH_MODE=ldap)
# VITE_AUTH_API_URL=https://your-api.example.com/api/auth

# ---- AI / Claude Integration ----
# Add your Anthropic API key to enable Claude-powered answers in Ask SOTI
# Get your key at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
